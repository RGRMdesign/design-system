{
  "primitives": {
    "color": {
      "neutral": {
        "0": { "$type": "color", "$value": "#ffffff" }
      },
      "gray": {
        "300": { "$type": "color", "$value": "#cccccc" },
        "600": { "$type": "color", "$value": "#666666" },
        "900": { "$type": "color", "$value": "#111111" }
      },
      "blue": {
        "600": { "$type": "color", "$value": "#0066cc" },
        "700": { "$type": "color", "$value": "#0052a3" }
      },
      "red": {
        "600": { "$type": "color", "$value": "#cc0000" }
      },
      "surface": {
        "subtle": { "$type": "color", "$value": "#f5f5f5" }
      }
    },
    "typography": {
      "fontFamily": {
        "sans": { "$type": "fontFamily", "$value": "system-ui, sans-serif" }
      },
      "fontSize": {
        "100": { "$type": "dimension", "$value": "0.875rem" },
        "200": { "$type": "dimension", "$value": "1rem" },
        "300": { "$type": "dimension", "$value": "1.25rem" }
      },
      "fontWeight": {
        "400": { "$type": "number", "$value": 400 },
        "700": { "$type": "number", "$value": 700 }
      }
    },
    "spacing": {
      "100": { "$type": "dimension", "$value": "0.25rem" },
      "200": { "$type": "dimension", "$value": "0.5rem" },
      "300": { "$type": "dimension", "$value": "1rem" },
      "400": { "$type": "dimension", "$value": "1.5rem" }
    },
    "radius": {
      "100": { "$type": "dimension", "$value": "4px" },
      "200": { "$type": "dimension", "$value": "6px" }
    },
    "focus": {
      "ring": {
        "width": { "$type": "dimension", "$value": "2px" },
        "offset": { "$type": "dimension", "$value": "2px" }
      }
    }
  },
  "semantic": {
    "color": {
      "background": {
        "canvas": { "$type": "color", "$value": "{primitives.color.neutral.0}" },
        "subtle": { "$type": "color", "$value": "{primitives.color.surface.subtle}" }
      },
      "text": {
        "primary": { "$type": "color", "$value": "{primitives.color.gray.900}" },
        "secondary": { "$type": "color", "$value": "{primitives.color.gray.600}" },
        "inverse": { "$type": "color", "$value": "{primitives.color.neutral.0}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{primitives.color.gray.300}" },
        "danger": { "$type": "color", "$value": "{primitives.color.red.600}" }
      },
      "action": {
        "primary": {
          "default": { "$type": "color", "$value": "{primitives.color.blue.600}" },
          "hover": { "$type": "color", "$value": "{primitives.color.blue.700}" }
        }
      }
    },
    "typography": {
      "body": {
        "fontFamily": { "$type": "fontFamily", "$value": "{primitives.typography.fontFamily.sans}" },
        "fontSize": { "$type": "dimension", "$value": "{primitives.typography.fontSize.200}" },
        "fontWeight": { "$type": "number", "$value": "{primitives.typography.fontWeight.400}" }
      },
      "label": {
        "fontSize": { "$type": "dimension", "$value": "{primitives.typography.fontSize.200}" },
        "fontWeight": { "$type": "number", "$value": "{primitives.typography.fontWeight.400}" }
      },
      "caption": {
        "fontSize": { "$type": "dimension", "$value": "{primitives.typography.fontSize.100}" }
      },
      "heading": {
        "fontWeight": { "$type": "number", "$value": "{primitives.typography.fontWeight.700}" },
        "fontSize": {
          "h1": { "$type": "dimension", "$value": "{primitives.typography.fontSize.300}" },
          "h2": { "$type": "dimension", "$value": "{primitives.typography.fontSize.200}" }
        }
      }
    },
    "focus": {
      "ring": {
        "width": { "$type": "dimension", "$value": "{primitives.focus.ring.width}" },
        "offset": { "$type": "dimension", "$value": "{primitives.focus.ring.offset}" }
      }
    }
  },
  "components": {
    "button": {
      "padding": {
        "y": { "$type": "dimension", "$value": "{primitives.spacing.200}" },
        "x": { "$type": "dimension", "$value": "{primitives.spacing.300}" }
      },
      "font": {
        "family": { "$type": "fontFamily", "$value": "{semantic.typography.body.fontFamily}" },
        "size": { "$type": "dimension", "$value": "{semantic.typography.body.fontSize}" },
        "weight": { "$type": "number", "$value": "{semantic.typography.body.fontWeight}" }
      },
      "border": {
        "width": { "$type": "dimension", "$value": "1px" },
        "radius": { "$type": "dimension", "$value": "{primitives.radius.200}" },
        "default": { "$type": "color", "$value": "{semantic.color.border.default}" }
      },
      "text": {
        "default": { "$type": "color", "$value": "{semantic.color.text.primary}" },
        "primary": { "$type": "color", "$value": "{semantic.color.text.inverse}" }
      },
      "background": {
        "default": { "$type": "color", "$value": "{semantic.color.background.subtle}" },
        "primary": {
          "default": { "$type": "color", "$value": "{semantic.color.action.primary.default}" },
          "hover": { "$type": "color", "$value": "{semantic.color.action.primary.hover}" }
        }
      },
      "focus": {
        "ringColor": { "$type": "color", "$value": "{semantic.color.action.primary.default}" },
        "ringWidth": { "$type": "dimension", "$value": "{semantic.focus.ring.width}" },
        "ringOffset": { "$type": "dimension", "$value": "{semantic.focus.ring.offset}" }
      },
      "disabled": {
        "opacity": { "$type": "number", "$value": 0.6 }
      }
    },
    "input": {
      "padding": {
        "y": { "$type": "dimension", "$value": "{primitives.spacing.200}" },
        "x": { "$type": "dimension", "$value": "{primitives.spacing.300}" }
      },
      "font": {
        "family": { "$type": "fontFamily", "$value": "{semantic.typography.body.fontFamily}" },
        "size": { "$type": "dimension", "$value": "{semantic.typography.body.fontSize}" }
      },
      "text": {
        "default": { "$type": "color", "$value": "{semantic.color.text.primary}" },
        "placeholder": { "$type": "color", "$value": "{semantic.color.text.secondary}" }
      },
      "background": {
        "default": { "$type": "color", "$value": "{semantic.color.background.canvas}" }
      },
      "border": {
        "width": { "$type": "dimension", "$value": "1px" },
        "radius": { "$type": "dimension", "$value": "{primitives.radius.100}" },
        "default": { "$type": "color", "$value": "{semantic.color.border.default}" },
        "invalid": { "$type": "color", "$value": "{semantic.color.border.danger}" }
      },
      "focus": {
        "ringColor": { "$type": "color", "$value": "{semantic.color.action.primary.default}" },
        "ringWidth": { "$type": "dimension", "$value": "{semantic.focus.ring.width}" },
        "ringOffset": { "$type": "dimension", "$value": "{semantic.focus.ring.offset}" }
      },
      "disabled": {
        "opacity": { "$type": "number", "$value": 0.6 }
      }
    },
    "formField": {
      "gap": { "$type": "dimension", "$value": "{primitives.spacing.100}" },
      "label": {
        "fontSize": { "$type": "dimension", "$value": "{semantic.typography.label.fontSize}" },
        "fontWeight": { "$type": "number", "$value": "{semantic.typography.label.fontWeight}" },
        "textColor": { "$type": "color", "$value": "{semantic.color.text.primary}" }
      },
      "help": {
        "fontSize": { "$type": "dimension", "$value": "{semantic.typography.caption.fontSize}" },
        "textColor": { "$type": "color", "$value": "{semantic.color.text.secondary}" }
      },
      "error": {
        "fontSize": { "$type": "dimension", "$value": "{semantic.typography.caption.fontSize}" },
        "textColor": { "$type": "color", "$value": "{semantic.color.border.danger}" }
      }
    },
    "base": {
      "body": {
        "fontFamily": { "$type": "fontFamily", "$value": "{semantic.typography.body.fontFamily}" },
        "fontSize": { "$type": "dimension", "$value": "{semantic.typography.body.fontSize}" },
        "fontWeight": { "$type": "number", "$value": "{semantic.typography.body.fontWeight}" },
        "textColor": { "$type": "color", "$value": "{semantic.color.text.primary}" },
        "backgroundColor": { "$type": "color", "$value": "{semantic.color.background.canvas}" }
      }
    }
  }
}
