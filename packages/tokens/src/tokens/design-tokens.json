{
  "color": {
    "background": {
      "primary": { "$type": "color", "$value": "#ffffff" },
      "secondary": { "$type": "color", "$value": "#f5f5f5" }
    },
    "text": {
      "primary": { "$type": "color", "$value": "#111111" },
      "secondary": { "$type": "color", "$value": "#666666" }
    },
    "action": {
      "primary": { "$type": "color", "$value": "#0088cc" },
      "primaryHover": { "$type": "color", "$value": "#0052a3" }
    },
    "border": {
      "default": { "$type": "color", "$value": "#cccccc" },
      "error": { "$type": "color", "$value": "#c00" }
    }
  },
  "typography": {
    "fontFamily": {
      "sans": { "$type": "fontFamily", "$value": "system-ui, sans-serif" }
    },
    "fontSize": {
      "sm": { "$type": "dimension", "$value": "0.875rem" },
      "md": { "$type": "dimension", "$value": "1rem" },
      "lg": { "$type": "dimension", "$value": "1.25rem" }
    },
    "fontWeight": {
      "normal": { "$type": "number", "$value": 400 },
      "bold": { "$type": "number", "$value": 700 }
    }
  },
  "spacing": {
    "xs": { "$type": "dimension", "$value": "0.25rem" },
    "sm": { "$type": "dimension", "$value": "0.5rem" },
    "md": { "$type": "dimension", "$value": "1rem" },
    "lg": { "$type": "dimension", "$value": "1.5rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "4px" },
    "md": { "$type": "dimension", "$value": "6px" }
  },
  "focus": {
    "ringWidth": { "$type": "dimension", "$value": "2px" },
    "ringOffset": { "$type": "dimension", "$value": "2px" }
  }
}
