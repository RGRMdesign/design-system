{
  "components": {
    "button": {
      "base": {
        "padding": {
          "y": {
            "$type": "dimension",
            "$value": "{primitives.spacing.200}"
          },
          "x": {
            "$type": "dimension",
            "$value": "{primitives.spacing.300}"
          }
        },
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{semantic.typography.body.font.family}"
          },
          "size": {
            "$type": "fontSizes",
            "$value": "{semantic.typography.body.font.size}"
          },
          "weight": {
            "$type": "number",
            "$value": "{semantic.typography.body.font.weight}"
          }
        },
        "border": {
          "width": {
            "$type": "dimension",
            "$value": "1px"
          },
          "radius": {
            "$type": "dimension",
            "$value": "{primitives.radius.200}"
          },
          "default": {
            "$type": "color",
            "$value": "{semantic.color.border.default}"
          }
        },
        "focus": {
          "ring": {
            "width": {
              "$type": "dimension",
              "$value": "{semantic.focus.ring.width}"
            },
            "offset": {
              "$type": "dimension",
              "$value": "{semantic.focus.ring.offset}"
            }
          }
        },
        "disabled": {
          "opacity": {
            "$type": "number",
            "$value": 0.6
          }
        }
      },
      "primary": {
        "background": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.action.primary.background.default}"
          },
          "hover": {
            "$type": "color",
            "$value": "{semantic.color.action.primary.background.hover}"
          }
        },
        "text": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.action.primary.foreground.default}"
          }
        },
        "border": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.action.primary.background.default}"
          },
          "hover": {
            "$type": "color",
            "$value": "{semantic.color.action.primary.background.hover}"
          }
        },
        "focus": {
          "ring": {
            "color": {
              "$type": "color",
              "$value": "{semantic.color.action.primary.background.default}"
            }
          }
        }
      },
      "secondary": {
        "background": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.background.subtle}"
          }
        },
        "text": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.text.primary}"
          }
        },
        "border": {
          "default": {
            "$type": "color",
            "$value": "{semantic.color.border.default}"
          }
        },
        "focus": {
          "ring": {
            "color": {
              "$type": "color",
              "$value": "{semantic.color.action.primary.background.default}"
            }
          }
        }
      }
    }
  }
}