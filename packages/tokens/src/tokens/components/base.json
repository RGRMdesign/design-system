{
  "components": {
    "base": {
      "body": {
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{semantic.typography.body.font.family}"
          },
          "size": {
            "$type": "fontSizes",
            "$value": "{semantic.typography.body.font.size}"
          },
          "weight": {
            "$type": "number",
            "$value": "{semantic.typography.body.font.weight}"
          }
        },
        "text": {
          "color": {
            "$type": "color",
            "$value": "{semantic.color.text.primary}"
          }
        },
        "background": {
          "color": {
            "$type": "color",
            "$value": "{semantic.color.background.canvas}"
          }
        }
      }
    }
  }
}