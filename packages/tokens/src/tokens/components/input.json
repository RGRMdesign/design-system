{
  "components": {
    "input": {
      "padding": {
        "y": {
          "$type": "dimension",
          "$value": "{primitives.spacing.200}"
        },
        "x": {
          "$type": "dimension",
          "$value": "{primitives.spacing.300}"
        }
      },
      "font": {
        "family": {
          "$type": "fontFamily",
          "$value": "{semantic.typography.body.font.family}"
        },
        "size": {
          "$type": "fontSizes",
          "$value": "{semantic.typography.body.font.size}"
        }
      },
      "text": {
        "default": {
          "$type": "color",
          "$value": "{semantic.color.text.primary}"
        },
        "placeholder": {
          "$type": "color",
          "$value": "{semantic.color.text.secondary}"
        }
      },
      "background": {
        "default": {
          "$type": "color",
          "$value": "{semantic.color.background.canvas}"
        }
      },
      "border": {
        "width": {
          "$type": "dimension",
          "$value": "1px"
        },
        "radius": {
          "$type": "dimension",
          "$value": "{primitives.radius.100}"
        },
        "default": {
          "$type": "color",
          "$value": "{semantic.color.border.default}"
        },
        "invalid": {
          "$type": "color",
          "$value": "{semantic.color.border.danger}"
        }
      },
      "focus": {
        "ring": {
          "color": {
            "$type": "color",
            "$value": "{semantic.color.action.primary.background.default}"
          },
          "width": {
            "$type": "dimension",
            "$value": "{semantic.focus.ring.width}"
          },
          "offset": {
            "$type": "dimension",
            "$value": "{semantic.focus.ring.offset}"
          }
        }
      },
      "disabled": {
        "opacity": {
          "$type": "number",
          "$value": 0.6
        }
      }
    }
  }
}