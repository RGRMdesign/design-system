          "$type": "dimension",
          "$value": "{semantic.typography.caption.fontSize}"
        },
        "textColor": {
          "$type": "color",
          "$value": "{semantic.color.text.secondary}"
        }
      },
      "error": {
        "fontSize": {
          "$type": "dimension",
          "$value": "{semantic.typography.caption.fontSize}"
        },
        "textColor": {
          "$type": "color",
          "$value": "{semantic.color.border.danger}"
        }
      }
