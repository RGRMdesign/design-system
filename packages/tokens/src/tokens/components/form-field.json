{
  "components": {
    "formField": {
      "gap": {
        "$type": "dimension",
        "$value": "{primitives.spacing.100}"
      },
      "label": {
        "font": {
          "size": {
            "$type": "fontSizes",
            "$value": "{semantic.typography.label.font.size}"
          },
          "weight": {
            "$type": "number",
            "$value": "{semantic.typography.label.font.weight}"
          }
        },
        "text": {
          "color": {
            "$type": "color",
            "$value": "{semantic.color.text.primary}"
          }
        }
      },
      "help": {
        "font": {
          "size": {
            "$type": "fontSizes",
            "$value": "{semantic.typography.caption.font.size}"
          }
        },
        "text": {
          "color": {
            "$type": "color",
            "$value": "{semantic.color.text.secondary}"
          }
        }
      },
      "error": {
        "font": {
          "size": {
            "$type": "fontSizes",
            "$value": "{semantic.typography.caption.font.size}"
          }
        },
        "text": {
          "color": {
            "$type": "color",
            "$value": "{semantic.color.border.danger}"
          }
        }
      }
    }
  }
}