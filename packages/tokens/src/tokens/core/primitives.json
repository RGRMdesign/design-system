            "$value": 400
          },
          "700": {
            "$type": "number",
            "$value": 700
          }
        }
      }
    },
    "spacing": {
      "100": {
        "$type": "dimension",
        "$value": "0.25rem"
      },
      "200": {
        "$type": "dimension",
        "$value": "0.5rem"
      },
      "300": {
        "$type": "dimension",
        "$value": "1rem"
      },
      "400": {
        "$type": "dimension",
        "$value": "1.5rem"
      }
    },
    "radius": {
      "100": {
        "$type": "dimension",
        "$value": "4px"
      },
      "200": {
        "$type": "dimension",
        "$value": "6px"
      }
