{
  "primitives": {
    "color": {
      "neutral": {
        "0": {
          "$type": "color",
          "$value": "#ffffff"
        }
      },
      "gray": {
        "300": {
          "$type": "color",
          "$value": "#cccccc"
        },
        "600": {
          "$type": "color",
          "$value": "#666666"
        },
        "900": {
          "$type": "color",
          "$value": "#111111"
        }
      },
      "blue": {
        "600": {
          "$type": "color",
          "$value": "#0066cc"
        },
        "700": {
          "$type": "color",
          "$value": "#0052a3"
        }
      },
      "red": {
        "600": {
          "$type": "color",
          "$value": "#cc0000"
        }
      },
      "surface": {
        "subtle": {
          "$type": "color",
          "$value": "#f5f5f5"
        }
      }
    },
    "typography": {
      "font": {
        "family": {
          "sans": {
            "$type": "fontFamily",
            "$value": "system-ui, sans-serif"
          }
        },
        "size": {
          "100": {
            "$type": "fontSizes",
