{
  "semantic": {
    "color": {
      "background": {
        "canvas": {
          "$type": "color",
          "$value": "{primitives.color.neutral.0}"
        },
        "subtle": {
          "$type": "color",
          "$value": "{primitives.color.surface.subtle}"
        }
      },
      "text": {
        "primary": {
          "$type": "color",
          "$value": "{primitives.color.gray.900}"
        },
        "secondary": {
          "$type": "color",
          "$value": "{primitives.color.gray.600}"
        },
        "inverse": {
          "$type": "color",
          "$value": "{primitives.color.neutral.0}"
        }
      },
      "border": {
        "default": {
          "$type": "color",
          "$value": "{primitives.color.gray.300}"
        },
        "danger": {
          "$type": "color",
          "$value": "{primitives.color.red.600}"
        }
      },
      "action": {
        "primary": {
          "background": {
            "default": {
              "$type": "color",
              "$value": "{primitives.color.blue.600}"
            },
            "hover": {
              "$type": "color",
              "$value": "{primitives.color.blue.700}"
            }
          },
          "foreground": {
            "default": {
              "$type": "color",
              "$value": "{semantic.color.text.inverse}"
            }
          }
        }
      }
    },
    "typography": {
      "body": {
        "font": {
          "family": {
            "$type": "fontFamily",
            "$value": "{primitives.typography.font.family.sans}"
          },
          "size": {
            "$type": "fontSizes",
            "$value": "{primitives.typography.font.size.200}"
          },
          "weight": {
            "$type": "number",
            "$value": "{primitives.typography.font.weight.400}"
          }
        }
      },
      "label": {
        "font": {
          "size": {
            "$type": "fontSizes",
            "$value": "{primitives.typography.font.size.200}"
          },
          "weight": {
            "$type": "number",
            "$value": "{primitives.typography.font.weight.400}"
          }
        }
      },
      "caption": {
        "font": {
          "size": {
            "$type": "fontSizes",
            "$value": "{primitives.typography.font.size.100}"
          }
        }
      },
      "heading": {
        "font": {
          "weight": {
            "$type": "number",
            "$value": "{primitives.typography.font.weight.700}"
          },
          "size": {
            "h1": {
              "$type": "fontSizes",
              "$value": "{primitives.typography.font.size.300}"
            },
            "h2": {
              "$type": "fontSizes",
              "$value": "{primitives.typography.font.size.200}"
            }
          }
        }
      }
    },
    "focus": {
      "ring": {
        "width": {
          "$type": "dimension",
          "$value": "{primitives.focus.ring.width}"
        },
        "offset": {
          "$type": "dimension",
          "$value": "{primitives.focus.ring.offset}"
        }
      }
    }
  }
}